# Server port (default: 8765)
PORT=8765

# Data directory for SQLite database and uploads
# DATA_DIR=~/.taskmanager-server

# LLM inference server URL (default: http://localhost:8766)
# LLM_SERVER_URL=http://localhost:8766

# Max file upload size in bytes (default: 52428800 = 50MB)
# MAX_FILE_SIZE=52428800

# Environment mode
NODE_ENV=development

# WARNING: Signature verification is always enforced regardless of this setting.
# This flag has no effect and exists only for documentation purposes.
# SKIP_SIG_VERIFY=0

# TLS/SSL (optional — enables wss:// and https://)
# TLS_CERT_PATH=/path/to/cert.pem
# TLS_KEY_PATH=/path/to/key.pem

# CORS allowed origins (comma-separated, optional, default: none)
# CORS_ORIGINS=http://localhost:5173
